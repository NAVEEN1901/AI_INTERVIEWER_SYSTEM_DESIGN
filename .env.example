# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talent_platform
DB_ECHO=false

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application
APP_NAME=AI Talent Acquisition Platform
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# File Upload
UPLOAD_DIR=uploads/resumes
MAX_FILE_SIZE_MB=10

# Email (Sprint 3)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Azure ML (Sprint 6)
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=
# AZURE_ML_WORKSPACE=

# Qdrant (Sprint 3)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# Neo4j (Sprint 5)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
